{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FinnhubSkillToolCall",
  "type": "object",
  "additionalProperties": false,
  "required": ["script", "operation", "args", "reason"],
  "properties": {
    "script": {
      "type": "string",
      "enum": [
        "symbols.py",
        "stock_market.py",
        "fundamentals.py",
        "news.py",
        "analyst.py",
        "technical.py"
      ]
    },
    "operation": {
      "type": "string"
    },
    "args": {
      "type": "object",
      "additionalProperties": {
        "type": ["string", "number", "integer", "boolean"]
      }
    },
    "reason": {
      "type": "string",
      "description": "Why this script and operation best match the user question."
    },
    "requires_symbol_resolution_first": {
      "type": "boolean",
      "default": false
    }
  }
}
