OPENAI_API_KEY=your_openai_compatible_api_key
OPENAI_BASE_URL=https://jeniya.top/v1

ROUTER_MODEL=gpt-4.1-mini
GRADER_MODEL=gpt-4.1-mini
REFLECTION_MODEL=gpt-4.1-mini
GEN_MODEL=gpt-4.1
EMBEDDING_MODEL=text-embedding-3-small

FINNHUB_API_KEY=
FINN_HUB_API=
TAVILY_API_KEY=

MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_COLLECTION=a_share_chunks
MILVUS_SQLITE_DB=financial database construction/data/metadata.sqlite
MILVUS_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
MILVUS_CANDIDATE_K=50
MILVUS_ADJACENT_WINDOW=1

# Finnhub skill execution.
# auto: use local skill LLM when SOURCE_API_SKILL_BASE_URL/MODEL or LOCAL_ANALYZER_* exists,
#       otherwise use compatibility script selection.
# off: force compatibility script selection.
# strict/llm/required: fail if the local skill LLM cannot select a tool call.
SOURCE_API_SKILL_MODE=auto
SOURCE_API_SKILL_BASE_URL=
SOURCE_API_SKILL_MODEL=
SOURCE_API_SKILL_API_KEY=not-needed
SOURCE_API_SKILL_TIMEOUT=30

TOP_K=6
WEB_TOP_K=5
RELIABILITY_THRESHOLD=0.75
MIN_RELEVANT_DOCS=2

# йҺөж’ізҙ‘з’әоҲңж•ұй–«еӨӢе«Ёз’ӢеҶӯзҳҜйҸғгғҘз№”й”ӣ?/true/yes/onй”ӣ?
DEBUG_ROUTING=0
# Query analyzer local small model. No model is downloaded automatically.
# Keep LOCAL_ANALYZER_* empty to use resolver/validator only.
QUERY_ANALYZER_MODE=hybrid
LOCAL_ANALYZER_BASE_URL=
LOCAL_ANALYZER_MODEL=
LOCAL_ANALYZER_API_KEY=not-needed
LOCAL_ANALYZER_TIMEOUT=20
QUERY_UNDERSTANDING_SKILL_PATH=./skills/financial_query_understanding_skill.md
ENTITY_RESOLVER_ENABLE_FINNHUB_LOOKUP=0
SHOW_ANSWER_SOURCES=1
